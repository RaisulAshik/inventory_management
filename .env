# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Master Database
MASTER_DB_HOST=localhost
MASTER_DB_PORT=4306
MASTER_DB_USERNAME=root
MASTER_DB_PASSWORD=
MASTER_DB_NAME=erp_master
MASTER_DB_SYNC=false

# Tenant Database (default connection settings)
TENANT_DB_HOST=localhost
TENANT_DB_PORT=4306
TENANT_DB_USERNAME=root
TENANT_DB_PASSWORD=
DB_SYNC=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@erp.com

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# AWS S3 (if STORAGE_TYPE=s3)
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGIN=http://localhost:8000,http://localhost:8001,http://localhost:4200
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8001,http://localhost:4200

# Logging
LOG_LEVEL=info